[Unit]
Description=AI RSS Twitter Cookie Rotate
After=network-online.target docker.service
Wants=docker.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/ai-RSS-person
ExecStart=/bin/bash /opt/ai-RSS-person/scripts/server/rotate_twitter_cookie.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
