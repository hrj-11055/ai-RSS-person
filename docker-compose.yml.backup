# RSS-person 项目 Docker 配置
# AI资讯自动生成与发布工具
# 仅包含必需的基础设施服务

services:
  # RSSHub - 本地轻量部署（仅 RSSHub + Redis，节省 ~479 MB 内存）
  rsshub:
    image: diygod/rsshub:latest
    container_name: rss-person-rsshub
    ports:
      - "1200:1200"
    environment:
      - NODE_ENV=production
      - CACHE_TYPE=redis
      - REDIS_URL=redis://redis:6379
      # Twitter API Token 配置（从浏览器开发者工具获取）
      # 获取方式：打开 https://twitter.com，按F12，切换到Network标签，刷新页面，
      # 找到任意请求的 Request Headers 中的 cookie 字段，复制 auth_token 值
      # RSSHub 推荐使用 TWITTER_AUTH_TOKEN（而非 TWITTER_COOKIE）
      - TWITTER_AUTH_TOKEN=51e551ff8318dd33286897285d4bf514d8250bec
    depends_on:
      - redis
    restart: unless-stopped
    networks:
      - rss-network

  # Redis - RSSHub缓存
  redis:
    image: redis:alpine
    container_name: rss-person-redis
    restart: unless-stopped
    networks:
      - rss-network

  # MySQL - wewe-rss 数据库（可选）
  # 如果不需要微信公众号源，可以注释掉以下整个服务块
  mysql:
    image: mysql:8.0
    container_name: rss-person-mysql
    environment:
      - MYSQL_ROOT_PASSWORD=wewe_root_password
      - MYSQL_DATABASE=wewe
      - MYSQL_USER=wewe
      - MYSQL_PASSWORD=wewe_password
    volumes:
      - mysql-data:/var/lib/mysql
    restart: unless-stopped
    networks:
      - rss-network

  # wewe-rss - 微信公众号订阅（可选）
  # 如果不需要微信公众号源，可以注释掉以下整个服务块
  wewe-rss:
    image: cooderl/wewe-rss:latest
    container_name: rss-person-wewe-rss
    ports:
      - "4000:4000"
    environment:
      - DATABASE_URL=mysql://wewe:wewe_password@mysql:3306/wewe
      - AUTH_CODE=wewe_secret_2024
      - SERVER_ORIGIN_URL=http://localhost:4000
    depends_on:
      - mysql
    restart: unless-stopped
    networks:
      - rss-network

networks:
  rss-network:
    driver: bridge

volumes:
  mysql-data:
