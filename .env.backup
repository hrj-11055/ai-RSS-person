
# ==================== DeepSeek API 配置 ====================
# DeepSeek API 密钥 (必填)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-ce0851ae8faa4f29a3ecc7281e05b81d

# DeepSeek API 基础 URL (可选，默认官方地址)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== 网络代理配置 (可选) ====================
# HTTP/HTTPS 代理地址（留空则不使用代理）
PROXY_URL=http://127.0.0.1:7897

# ==================== RSSHub 配置 ====================
# RSSHub 服务地址 (用于 Twitter 等特殊源)
RSSHUB_HOST=http://localhost:1200

# ==================== 应用配置 ====================
# 每个源最多抓取文章数
MAX_ITEMS_PER_SOURCE=3

# 报告中最多包含文章数
MAX_ARTICLES_IN_REPORT=30

# 报告输出目录
OUTPUT_DIR=reports

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 云服务器配置 ====================
# 服务器地址
CLOUD_SERVER_HOST=8.135.37.159
# SSH端口
CLOUD_SERVER_PORT=22
# SSH用户名
CLOUD_SERVER_USER=root
# SSH私钥路径（推荐使用密钥认证）
CLOUD_SERVER_KEY_PATH=/Users/MarkHuang/.ssh/id_rsa
# 远程保存路径
CLOUD_SERVER_REMOTE_PATH=/var/www/html/reports
# 上传方式: sftp, http, ftp
UPLOAD_METHOD=sftp

# JSON 文件远程上传路径（可选，默认为 /var/www/json/report）
CLOUD_SERVER_JSON_REMOTE_PATH=/var/www/json/report

# ==================== 邮箱发送配置 ====================
# SMTP 服务器地址（QQ邮箱）
SMTP_SERVER=smtp.qq.com

# SMTP 端口 (SSL通常为465, TLS通常为587)
SMTP_PORT=465

# 发件人邮箱（你的QQ邮箱）
SENDER_EMAIL=1415994589@qq.com

# 邮箱授权码 (⚠️ 注意：不是QQ密码，是SMTP授权码)
SENDER_PASSWORD=zdejmnzlzfblbaeb

# 收件人邮箱（多个收件人用逗号分隔，如：a@xx.com,b@xx.com）
RECEIVER_EMAIL=ainfo@aicoming.cn

# 邮件抄送（可选）
CC_EMAIL=

# 邮件密送（可选）
BCC_EMAIL=
