# ==================== 仿真环境配置（不会影响生产定时任务） ====================
# 使用方式：bash scripts/dev/run_simulation.sh
# 说明：该配置专用于“全流程仿真”，默认禁用上传和邮件，只写入 simulation 目录。

# ---- AI 配置 ----
# 真实 AI 分析时必须填真实 key（脚本会在此项为占位值时尝试从 .env 读取）
DEEPSEEK_API_KEY=simulation_key_placeholder
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ---- YAML 路径（仅三源仿真） ----
SOURCES_YAML_PATH=/Users/MarkHuang/ai-RSS-person/config/sources.sim.yaml
WEIGHTS_YAML_PATH=/Users/MarkHuang/ai-RSS-person/config/weights.yaml

# ---- RSS 抓取窗口 ----
RSSHUB_HOST=http://localhost:1200
PROXY_URL=
MAX_ITEMS_PER_SOURCE=5
TIME_WINDOW_HOURS=48

# ---- 输出与日志（隔离到 simulation 路径） ----
OUTPUT_DIR=reports/simulation
MAX_ARTICLES_IN_REPORT=20
LOG_LEVEL=INFO

# ---- Pipeline（隔离缓存，不复用生产缓存） ----
PIPELINE_CACHE_DIR=reports/simulation/.pipeline
RESUME_FROM_CACHE=false
STAGE_RETRY_COUNT=1
STAGE_RETRY_DELAY_SECONDS=1

# ---- 禁用外部副作用（防止影响真实环境） ----
UPLOAD_ENABLED=false
UPLOAD_METHOD=sftp
EMAIL_ENABLED=false
EMAIL_WHEN_UPLOAD_FAIL=false
