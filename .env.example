# ==================== AI-RSS-PERSON 环境变量示例 ====================
# 复制此文件为 .env 并填入真实值
# 配置优先级: ENV > core/config.yaml > constants.py

# ---------------- DeepSeek (必填) ----------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ---------------- 路径配置 ----------------
# 可选: 自定义源/权重 YAML 路径（默认使用项目内 config/）
SOURCES_YAML_PATH=/Users/MarkHuang/ai-RSS-person/config/sources.yaml
WEIGHTS_YAML_PATH=/Users/MarkHuang/ai-RSS-person/config/weights.yaml

# ---------------- RSS 配置 ----------------
RSSHUB_HOST=http://localhost:1200
PROXY_URL=http://127.0.0.1:7897
MAX_ITEMS_PER_SOURCE=7
TIME_WINDOW_HOURS=24
ENABLE_PROXY_IP_UPDATE=false

# RSSHub 运行环境（npm/systemd/pm2 通用）
PROXY_URI=http://127.0.0.1:7897
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# 可选：每周自动轮换脚本读取原始 cookie 字符串的路径（应仅 root 可读）
TWITTER_COOKIE_SOURCE_FILE=/opt/ai-RSS-person/secrets/twitter_cookie.txt

# RSSHub 进程管理（npm/systemd/pm2 二选一配置）
# 方式1（推荐）：systemd 服务名，例如 rsshub.service
RSSHUB_SERVICE_NAME=rsshub.service
# 方式2：自定义重启命令（优先级最高）
RSSHUB_RESTART_CMD=
# 方式3：pm2 进程名（若使用 pm2）
RSSHUB_PM2_NAME=
# 可选：启动命令（start-rsshub-server.sh 使用）
RSSHUB_START_CMD=

# ---------------- 报告配置 ----------------
OUTPUT_DIR=reports
# 服务器同机部署时可配置：日报 JSON 复制到目标目录（例如 /var/www/json/report）
LOCAL_TARGET_DIR=
MAX_ARTICLES_IN_REPORT=40
LOG_LEVEL=INFO

# ---------------- 流水线配置 ----------------
PIPELINE_CACHE_DIR=reports/.pipeline
RESUME_FROM_CACHE=true
STAGE_RETRY_COUNT=1
STAGE_RETRY_DELAY_SECONDS=3
PIPELINE_LOCK_FILE=/tmp/ai-rss-daily.lock

# ---------------- 去重阈值配置（可选） ----------------
# 同日排序候选去重（标题字符相似）
INTRADAY_TITLE_SIM_THRESHOLD_STRONG=0.72
INTRADAY_TITLE_SIM_THRESHOLD_NUMERIC=0.43
INTRADAY_COMMON_SUBSTR_MIN=6

# 最终产出去重（标题+摘要字符相似）
FINAL_CONTENT_SIM_THRESHOLD_STRONG=0.72
FINAL_CONTENT_SIM_THRESHOLD_NUMERIC=0.40
FINAL_CONTENT_OVERLAP_THRESHOLD_NUMERIC=0.45
FINAL_CONTENT_COMMON_SUBSTR_MIN=6
FINAL_CONTENT_TITLE_SIM_GUARD=0.42

# ---------------- 产物保留策略 ----------------
RETENTION_REPORT_DAYS=14
RETENTION_PIPELINE_DAYS=30

# ---------------- 上传配置 ----------------
UPLOAD_ENABLED=true
UPLOAD_METHOD=sftp   # sftp | http | ftp

# 当 UPLOAD_ENABLED=true 且 UPLOAD_METHOD=sftp/ftp 时必填:
CLOUD_SERVER_HOST=your.server.host
CLOUD_SERVER_PORT=22
CLOUD_SERVER_USER=your_user

# 认证（sftp/ftp 二选一）
CLOUD_SERVER_PASSWORD=
CLOUD_SERVER_KEY_PATH=

# 远程路径
CLOUD_SERVER_REMOTE_PATH=/var/www/html/reports
CLOUD_SERVER_JSON_REMOTE_PATH=/var/www/json/report

# 当 UPLOAD_METHOD=http 时必填:
HTTP_UPLOAD_URL=
HTTP_UPLOAD_TOKEN=

# ---------------- 邮件配置 ----------------
EMAIL_ENABLED=false
EMAIL_WHEN_UPLOAD_FAIL=false

# 当 EMAIL_ENABLED=true 时必填:
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SENDER_EMAIL=your_email@qq.com
SENDER_PASSWORD=your_email_authorization_code
RECEIVER_EMAIL=receiver@example.com

# 可选抄送/密送
CC_EMAIL=
BCC_EMAIL=
