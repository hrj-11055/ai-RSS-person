# ==================== 环境变量配置示例 ====================
# 复制此文件为 .env 并填入真实值
# ⚠️ 警告：.env 文件包含敏感信息，切勿提交到 Git！

# ---------------- DeepSeek API 配置 ----------------
# DeepSeek API 密钥 (必填)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础 URL (可选，默认官方地址)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------------- 邮箱发送配置 (可选) ----------------
# SMTP 服务器地址
SMTP_SERVER=smtp.qq.com

# SMTP 端口 (SSL通常为465, TLS通常为587)
SMTP_PORT=465

# 发件人邮箱
SENDER_EMAIL=your_email@qq.com

# 邮箱授权码 (注意：不是登录密码，是SMTP授权码)
SENDER_PASSWORD=your_email_authorization_code

# 收件人邮箱
RECEIVER_EMAIL=receiver@example.com

# ---------------- 网络代理配置 (可选) ----------------
# HTTP/HTTPS 代理地址
PROXY_URL=http://127.0.0.1:7897

# ---------------- RSSHub 配置 ----------------
# RSSHub 服务地址 (用于 Twitter 等特殊源)
# 方案 A：公开实例（推荐）- 占用 0 MB，无需维护
# 备选实例: https://rsshub.app, https://hub.slarker.me
RSSHUB_HOST=https://rsshub.pseudoyu.com
# 方案 B：本地轻量部署 - 占用 ~379 MB，稳定可控
# RSSHUB_HOST=http://localhost:1200
# 可用实例列表: https://docs.rsshub.app/guide/instances

# ---------------- 应用配置 ----------------
# 每个源最多抓取文章数
MAX_ITEMS_PER_SOURCE=3

# 报告中最多包含文章数
MAX_ARTICLES_IN_REPORT=20

# 报告输出目录
OUTPUT_DIR=reports

# ---------------- 微信公众号配置 (可选) ----------------
# 微信 App ID (如果使用微信自动发布)
WECHAT_APP_ID=your_wechat_app_id

# 微信 App Secret
WECHAT_APP_SECRET=your_wechat_app_secret

# ---------------- 日志配置 ----------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径 (可选，默认输出到控制台)
LOG_FILE=

# ---------------- 云服务器配置 (daily_report_PRO_cloud.py) ----------------
# 服务器地址
CLOUD_SERVER_HOST=8.135.37.159

# SSH端口
CLOUD_SERVER_PORT=22

# SSH用户名
CLOUD_SERVER_USER=root

# SSH密码（使用密码登录时填写）
# CLOUD_SERVER_PASSWORD=your_ssh_password

# SSH私钥路径（优先使用密钥登录，推荐）
# CLOUD_SERVER_KEY_PATH=/path/to/your/private/key

# 远程保存路径
CLOUD_SERVER_REMOTE_PATH=/var/www/html/reports

# JSON 文件远程上传路径（可选，默认为 /var/www/json/report）
CLOUD_SERVER_JSON_REMOTE_PATH=/var/www/json/report

# 上传方式: sftp, http, ftp
UPLOAD_METHOD=sftp

# HTTP上传配置（如果使用HTTP方式）
# HTTP_UPLOAD_URL=http://your-server.com/api/upload
# HTTP_UPLOAD_TOKEN=your_upload_token

# ==================== Docker 自动启动 ====================
# 如果需要定时任务运行前自动检查并启动Docker服务，
# 请使用 daily_report_with_docker_check.sh 替代直接运行 python 脚本
# 
# 更新定时任务配置:
# launchctl list | grep aireport
# 
# 修改 .plist 文件中的 ProgramArguments:
# <key>ProgramArguments</key>
#   <array>
#     <string>/Users/MarkHuang/ai-RSS-person/daily_report_with_docker_check.sh</string>
#   </array>
