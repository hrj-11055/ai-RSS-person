# ==================== AI-RSS-PERSON 环境变量示例 ====================
# 复制此文件为 .env 并填入真实值
# 配置优先级: ENV > core/config.yaml > constants.py

# ---------------- DeepSeek (必填) ----------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ---------------- 路径配置 ----------------
# 可选: 自定义源/权重 YAML 路径（默认使用项目内 config/）
SOURCES_YAML_PATH=/Users/MarkHuang/ai-RSS-person/config/sources.yaml
WEIGHTS_YAML_PATH=/Users/MarkHuang/ai-RSS-person/config/weights.yaml

# ---------------- RSS 配置 ----------------
RSSHUB_HOST=http://localhost:1200
PROXY_URL=http://127.0.0.1:7897
MAX_ITEMS_PER_SOURCE=7
TIME_WINDOW_HOURS=24
ENABLE_PROXY_IP_UPDATE=false

# RSSHub 容器环境（docker-compose 使用）
PROXY_URI=http://127.0.0.1:7897
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ---------------- 报告配置 ----------------
OUTPUT_DIR=reports
MAX_ARTICLES_IN_REPORT=40
LOG_LEVEL=INFO

# ---------------- 流水线配置 ----------------
PIPELINE_CACHE_DIR=reports/.pipeline
RESUME_FROM_CACHE=true
STAGE_RETRY_COUNT=1
STAGE_RETRY_DELAY_SECONDS=3
PIPELINE_LOCK_FILE=/tmp/ai-rss-daily.lock

# ---------------- 产物保留策略 ----------------
RETENTION_REPORT_DAYS=14
RETENTION_PIPELINE_DAYS=30

# ---------------- 上传配置 ----------------
UPLOAD_ENABLED=true
UPLOAD_METHOD=sftp   # sftp | http | ftp

# 当 UPLOAD_ENABLED=true 且 UPLOAD_METHOD=sftp/ftp 时必填:
CLOUD_SERVER_HOST=your.server.host
CLOUD_SERVER_PORT=22
CLOUD_SERVER_USER=your_user

# 认证（sftp/ftp 二选一）
CLOUD_SERVER_PASSWORD=
CLOUD_SERVER_KEY_PATH=

# 远程路径
CLOUD_SERVER_REMOTE_PATH=/var/www/html/reports
CLOUD_SERVER_JSON_REMOTE_PATH=/var/www/json/report

# 当 UPLOAD_METHOD=http 时必填:
HTTP_UPLOAD_URL=
HTTP_UPLOAD_TOKEN=

# ---------------- 邮件配置 ----------------
EMAIL_ENABLED=false
EMAIL_WHEN_UPLOAD_FAIL=false

# 当 EMAIL_ENABLED=true 时必填:
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SENDER_EMAIL=your_email@qq.com
SENDER_PASSWORD=your_email_authorization_code
RECEIVER_EMAIL=receiver@example.com

# 可选抄送/密送
CC_EMAIL=
BCC_EMAIL=
